AEGISSEC_APP_NAME=aegissec
AEGISSEC_API_HOST=0.0.0.0
AEGISSEC_API_PORT=8000
AEGISSEC_WEB_HOST=0.0.0.0
AEGISSEC_WEB_PORT=5173
AEGISSEC_FRONTEND_ORIGIN=http://127.0.0.1:5173
AEGISSEC_API_AUTH_MODE=disabled
AEGISSEC_API_AUTH_TOKEN=
AEGISSEC_API_AUTH_USERNAME=
AEGISSEC_API_AUTH_PASSWORD=
AEGISSEC_QUEUE_BACKEND=in_process
AEGISSEC_REDIS_URL=
AEGISSEC_KALI_IMAGE=aegissec-kali:latest
AEGISSEC_KALI_INSTALL_CTF_TOOLS=1
AEGISSEC_KALI_CTF_INSTALL_MODE=python
AEGISSEC_KALI_INSTALL_SKILL_TOOLS=1
AEGISSEC_KALI_SKILL_TOOL_PROFILE=lean
AEGISSEC_KALI_INSTALL_GCP_TOOLS=0
AEGISSEC_KALI_INSTALL_AZURE_TOOLS=0
AEGISSEC_KALI_INSTALL_BROWSER_TOOLS=0
AEGISSEC_KALI_APT_MIRROR=http://mirrors.aliyun.com/kali
AEGISSEC_KALI_MAX_IMAGE_SIZE_GB=20
AEGISSEC_KALI_FORCE_REBUILD=0
AEGISSEC_RUNTIME_CONTAINER_NAME=aegissec-kali-runtime
AEGISSEC_RUNTIME_WORKSPACE_CONTAINER_PATH=/workspace
AEGISSEC_RUNTIME_DEFAULT_TIMEOUT_SECONDS=90
AEGISSEC_RUNTIME_RECENT_RUNS_LIMIT=10
AEGISSEC_RUNTIME_RECENT_ARTIFACTS_LIMIT=20
AEGISSEC_MCP_IMPORT_PATHS=[]
LLM_API_KEY=
LLM_API_BASE_URL=
LLM_DEFAULT_MODEL=
AEGISSEC_LLM_REQUEST_TIMEOUT_SECONDS=120
AEGISSEC_LLM_MAX_OUTPUT_TOKENS=2048
AEGISSEC_CHAT_AUTO_TOOL_TURN_LIMIT=12
AEGISSEC_CHAT_AUTO_TOOL_BUDGET_CYCLES=1
AEGISSEC_LLM_MAX_CONCURRENCY=6
AEGISSEC_LLM_RATE_LIMIT_RPM=15000
AEGISSEC_LLM_RATE_LIMIT_TPM_TOTAL=40000000
AEGISSEC_LLM_RATE_LIMIT_TPM_INPUT=36000000
AEGISSEC_LLM_RATE_LIMIT_TPM_OUTPUT=4000000
AEGISSEC_LLM_RATE_LIMIT_SAFETY_RATIO=0.2
AEGISSEC_LLM_RATE_LIMIT_MAX_RETRIES=2
AEGISSEC_LLM_RATE_LIMIT_BASE_DELAY_MS=500
AEGISSEC_LLM_RATE_LIMIT_MAX_DELAY_SECONDS=30
VITE_API_BASE_URL=http://127.0.0.1:8000
# --- Agent loop hard stops ---
AEGISSEC_AGENT_MAX_ELAPSED_SECONDS=180
AEGISSEC_AGENT_MAX_TOTAL_TOOL_CALLS=20
AEGISSEC_AGENT_MAX_NO_PROGRESS_TURNS=3
# --- Skill routing ---
AEGISSEC_SKILL_AUTOROUTE_ENABLED=false
AEGISSEC_SKILL_AUTOROUTE_PRELOAD_ENABLED=false
AEGISSEC_SKILL_CACHE_TTL_SECONDS=300
# --- Session pagination ---
AEGISSEC_SESSION_INITIAL_MESSAGE_LIMIT=50
AEGISSEC_SESSION_INITIAL_STEP_LIMIT=100
AEGISSEC_PROMPT_HISTORY_MESSAGE_LIMIT=30
# --- Docker lazy init ---
AEGISSEC_DOCKER_LAZY_INIT=true
# --- Startup recovery ---
AEGISSEC_RECOVER_ON_STARTUP=false
# --- Event debouncing ---
AEGISSEC_EVENT_DEBOUNCE_MS=250
AEGISSEC_ATTACK_GRAPH_UPDATE_DEBOUNCE_MS=1000
