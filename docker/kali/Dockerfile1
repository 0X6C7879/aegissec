FROM kalilinux/kali-rolling

ARG INSTALL_CTF_TOOLS=1
ARG CTF_INSTALL_MODE=python
ARG INSTALL_SKILL_TOOLS=1
ARG SKILL_TOOL_PROFILE=lean
ARG INSTALL_GCP_TOOLS=0
ARG INSTALL_BROWSER_TOOLS=0
ARG INSTALL_AZURE_TOOLS=0
ARG KALI_APT_MIRROR=http://mirrors.aliyun.com/kali
ARG CTF_INSTALLER_SHA=unknown

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/root/.local/bin:/root/go/bin:/root/.ctf-tools/venv/bin:/root/.aegissec-skill-tools/venv/bin:${PATH}"

LABEL aegissec.install_ctf_tools="${INSTALL_CTF_TOOLS}"
LABEL aegissec.ctf_install_mode="${CTF_INSTALL_MODE}"
LABEL aegissec.install_skill_tools="${INSTALL_SKILL_TOOLS}"
LABEL aegissec.skill_tool_profile="${SKILL_TOOL_PROFILE}"
LABEL aegissec.install_gcp_tools="${INSTALL_GCP_TOOLS}"
LABEL aegissec.install_browser_tools="${INSTALL_BROWSER_TOOLS}"
LABEL aegissec.install_azure_tools="${INSTALL_AZURE_TOOLS}"
LABEL aegissec.kali_apt_mirror="${KALI_APT_MIRROR}"
LABEL aegissec.ctf_installer_sha="${CTF_INSTALLER_SHA}"

# Network and mirror hardening
RUN set -eux; \
    printf 'Acquire::Retries "10";\nAcquire::http::Timeout "30";\nAcquire::https::Timeout "30";\nAcquire::ForceIPv4 "true";\n' > /etc/apt/apt.conf.d/99aegissec-network; \
    if [ -f /etc/apt/sources.list.d/kali.sources ]; then \
        sed -i "s|http://http.kali.org/kali|${KALI_APT_MIRROR}|g" /etc/apt/sources.list.d/kali.sources; \
        sed -i "s|https://http.kali.org/kali|${KALI_APT_MIRROR}|g" /etc/apt/sources.list.d/kali.sources; \
        sed -i "s|https://kali.download/kali|${KALI_APT_MIRROR}|g" /etc/apt/sources.list.d/kali.sources; \
    fi; \
    if [ -f /etc/apt/sources.list ]; then \
        sed -i "s|http://http.kali.org/kali|${KALI_APT_MIRROR}|g" /etc/apt/sources.list; \
        sed -i "s|https://http.kali.org/kali|${KALI_APT_MIRROR}|g" /etc/apt/sources.list; \
        sed -i "s|https://kali.download/kali|${KALI_APT_MIRROR}|g" /etc/apt/sources.list; \
    fi

# Install only competition-required tooling (without kali-linux-default)
RUN set -eux; \
    apt-get update -o Acquire::Retries=5; \
    apt-get install -y -o Acquire::Retries=5 --fix-missing --no-install-recommends \
        bash \
        zsh \
        ca-certificates \
        curl \
        git \
        gnupg \
        jq \
        libcap2-bin \
        procps \
        python3 \
        python3-pip \
        python3-venv \
        sudo \
        tini \
        wget \
        dnsutils \
        nmap \
        whois \
        amass \
        arp-scan \
        arjun \
        awscli \
        bloodhound \
        chisel \
        dnsenum \
        dnsrecon \
        enum4linux \
        evil-winrm \
        exploitdb \
        feroxbuster \
        gobuster \
        hydra \
        kubectl \
        ldap-utils \
        mitmproxy \
        mimikatz \
        netdiscover \
        netexec \
        nfs-common \
        nikto \
        onesixtyone \
        powershell \
        python3-impacket \
        recon-ng \
        rubeus \
        sharphound \
        smbclient \
        smbmap \
        snmp \
        snmpcheck \
        theharvester \
        tshark \
        whatweb \
        wfuzz; \
    if [ "${SKILL_TOOL_PROFILE}" = "core" ] || [ "${SKILL_TOOL_PROFILE}" = "full" ] || [ "${CTF_INSTALL_MODE}" = "go" ] || [ "${CTF_INSTALL_MODE}" = "all" ]; then \
        apt-get install -y -o Acquire::Retries=5 --fix-missing --no-install-recommends golang-go cargo; \
    else \
        echo "[aegissec-kali] Skip go/cargo toolchain installation"; \
    fi; \
    if [ "${CTF_INSTALL_MODE}" = "gems" ] || [ "${CTF_INSTALL_MODE}" = "all" ]; then \
        apt-get install -y -o Acquire::Retries=5 --fix-missing --no-install-recommends ruby; \
    else \
        echo "[aegissec-kali] Skip ruby toolchain installation"; \
    fi; \
    if [ "${INSTALL_AZURE_TOOLS}" = "1" ]; then \
        apt-get install -y -o Acquire::Retries=5 --fix-missing --no-install-recommends azure-cli; \
    else \
        echo "[aegissec-kali] Skip Azure CLI installation"; \
    fi; \
    if [ "${INSTALL_GCP_TOOLS}" = "1" ]; then \
        install -d -m 0755 /etc/apt/keyrings; \
        wget -qO- https://packages.cloud.google.com/apt/doc/apt-key.gpg | gpg --dearmor -o /etc/apt/keyrings/google-cloud.gpg; \
        chmod a+r /etc/apt/keyrings/google-cloud.gpg; \
        printf 'deb [signed-by=/etc/apt/keyrings/google-cloud.gpg] https://packages.cloud.google.com/apt cloud-sdk main\n' > /etc/apt/sources.list.d/google-cloud-cli.list; \
        apt-get update -o Acquire::Retries=5; \
        apt-get install -y -o Acquire::Retries=5 --fix-missing --no-install-recommends google-cloud-cli; \
    else \
        echo "[aegissec-kali] Skip Google Cloud CLI installation"; \
    fi; \
    if [ "${INSTALL_BROWSER_TOOLS}" = "1" ]; then \
        install -d -m 0755 /etc/apt/keyrings; \
        wget -qO- https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor -o /etc/apt/keyrings/google-linux.gpg; \
        chmod a+r /etc/apt/keyrings/google-linux.gpg; \
        if [ "$(dpkg --print-architecture)" = "amd64" ]; then \
            printf 'Types: deb\nURIs: https://dl.google.com/linux/chrome/deb/\nSuites: stable\nComponents: main\nArchitectures: amd64\nSigned-By: /etc/apt/keyrings/google-linux.gpg\n' > /etc/apt/sources.list.d/google-chrome.sources; \
            apt-get update -o Acquire::Retries=5; \
            apt-get install -y -o Acquire::Retries=5 --fix-missing --no-install-recommends google-chrome-stable; \
        else \
            printf '[aegissec-kali] Skip Google Chrome install on unsupported arch: %s\n' "$(dpkg --print-architecture)"; \
        fi; \
    else \
        echo "[aegissec-kali] Skip browser tooling installation"; \
    fi; \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

WORKDIR /opt/aegissec

COPY scripts/install_ctf_tools.sh ./scripts/install_ctf_tools.sh
COPY docker/kali/install_skill_tools.sh ./docker/kali/install_skill_tools.sh

RUN chmod +x ./scripts/install_ctf_tools.sh ./docker/kali/install_skill_tools.sh \
    && if [ "${INSTALL_CTF_TOOLS}" = "1" ]; then \
        ./scripts/install_ctf_tools.sh "${CTF_INSTALL_MODE}"; \
       else \
        echo "[aegissec-kali] Skip CTF baseline installation"; \
       fi \
    && if [ "${INSTALL_SKILL_TOOLS}" = "1" ]; then \
        ./docker/kali/install_skill_tools.sh "${SKILL_TOOL_PROFILE}"; \
       else \
        echo "[aegissec-kali] Skip skill extras installation"; \
       fi

RUN printf '%s\n' 'export PATH="/root/.local/bin:/root/go/bin:/root/.ctf-tools/venv/bin:/root/.aegissec-skill-tools/venv/bin:$PATH"' > /etc/profile.d/aegissec-path.sh \
    && chmod 0644 /etc/profile.d/aegissec-path.sh \
    && printf '\nexport PATH="/root/.local/bin:/root/go/bin:/root/.ctf-tools/venv/bin:/root/.aegissec-skill-tools/venv/bin:$PATH"\n' >> /etc/zsh/zshenv

WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/bin/zsh"]
